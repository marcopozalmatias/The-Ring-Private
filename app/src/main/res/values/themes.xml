<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="ShapeAppearance.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Base.Theme.TheRingPrivate" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#A30000</item>
        <item name="colorPrimaryVariant">#FF0000</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="logoSource">@drawable/logo_the_ring_transparente_negro</item>
    </style>

    <style name="Theme.TheRingPrivate" parent="Base.Theme.TheRingPrivate" />

    <style name="CustomActiveIndicatorStyle" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#33A30000</item>
        <item name="android:height">80dp</item>
        <item name="android:width">80dp</item>
        <item name="android:radius">40dp</item>
        <item name="android:layout_gravity">center_horizontal|bottom</item>
        <item name="android:layout_marginBottom">-20dp</item>
    </style>

    <style name="TemaAjustesPremium" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/color_fondo_ajustes</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <attr name="logoSource" format="reference" />
</resources>