<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:backgroundTint="@color/cardBackground"
    android:paddingVertical="12dp"
    android:elevation="8dp">

    <!-- Sección Idioma -->
    <LinearLayout
        android:id="@+id/layoutSectionLang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/idioma"
                android:layout_marginEnd="8dp"
                app:tint="@color/settingsIconTint"/>

            <TextView
                android:id="@+id/tvLangTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_language"
                android:textColor="@color/rojo_ring"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btnLangEs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🇪🇸 ES"
                android:textColor="@color/textColorPrimary"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@color/dividerColor"
                android:layout_marginHorizontal="12dp"/>

            <TextView
                android:id="@+id/btnLangEn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🇬🇧 EN"
                android:textColor="@color/textColorPrimary"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/dividerLang"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dividerColor"
        android:layout_marginHorizontal="20dp"/>

    <!-- Sección Tema -->
    <LinearLayout
        android:id="@+id/layoutSectionTheme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/modo_oscuro"
                android:layout_marginEnd="8dp"
                app:tint="@color/settingsIconTint"/>

            <TextView
                android:id="@+id/tvThemeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_theme"
                android:textColor="@color/rojo_ring"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btnThemeLight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/theme_light_internal"
                android:textColor="@color/textColorPrimary"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@color/dividerColor"
                android:layout_marginHorizontal="12dp"/>

            <TextView
                android:id="@+id/btnThemeDark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/theme_dark_internal"
                android:textColor="@color/textColorPrimary"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/dividerTheme"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dividerColor"
        android:layout_marginHorizontal="20dp"/>

    <!-- Opción MÁS -->
    <LinearLayout
        android:id="@+id/btnMas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ajustetransparente"
            android:layout_marginEnd="10dp"
            app:tint="@color/settingsIconTint"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/more_options"
            android:textColor="@color/rojo_ring"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>